{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VimMo",
  "scopeName": "source.vmo",
  "fileTypes": [
    "vmo"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#function-definition" },
    { "include": "#class-definition" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vmo",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vmo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vmo",
              "match": "\\\\[ntr\\\\\"']"
            }
          ]
        },
        {
          "name": "string.quoted.single.vmo",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.vmo",
              "match": "\\\\[ntr\\\\\"']"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vmo",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.vmo",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vmo",
          "match": "\\b(if|else|for|in|while|break|continue|return)\\b"
        },
        {
          "name": "keyword.declaration.vmo",
          "match": "\\b(let|const|fn|class|async|await)\\b"
        },
        {
          "name": "keyword.other.vmo",
          "match": "\\b(import|from|echo|new|self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vmo",
          "match": "\\b(number|string|bool|list|dict|any|void)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vmo",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vmo",
          "match": "\\bnull\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.vmo",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.vmo",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.vmo",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.vmo",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.vmo",
          "match": "(\\+=|-=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.vmo",
          "match": "(\\+(?!=)|-(?!=)|\\*|/|%)"
        },
        {
          "name": "keyword.operator.string-concat.vmo",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.vmo",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brackets.vmo",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parameters.vmo",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma.vmo",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.vmo",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.vmo",
          "match": "\\.(?!\\.)"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "async fn name(...)",
          "match": "\\b(async\\s+fn|fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.vmo" },
            "2": { "name": "entity.name.function.vmo" }
          }
        }
      ]
    },
    "class-definition": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.vmo" },
            "2": { "name": "entity.name.type.class.vmo" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "function call",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.vmo" }
          }
        },
        {
          "name": "variable.other.vmo",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
